{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 0
    },
    "namespace": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "gpu": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "resourceName": {
          "type": "string",
          "minLength": 1
        },
        "count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "adapters": {
      "type": "object",
      "properties": {
        "queue": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["sqs", "mock"]
            },
            "envName": {
              "type": "string",
              "minLength": 1
            },
            "sqs": {
              "type": "object",
              "properties": {
                "queueURL": {
                  "type": "string"
                },
                "awsRegion": {
                  "type": "string",
                  "minLength": 1
                },
                "queueLength": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "mock": {
              "type": "object",
              "properties": {
                "queueName": {
                  "type": "string"
                }
              }
            }
          }
        },
        "storage": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["s3", "local", "minio"]
            },
            "assetEnvName": {
              "type": "string",
              "minLength": 1
            },
            "outputEnvName": {
              "type": "string",
              "minLength": 1
            },
            "s3": {
              "type": "object",
              "properties": {
                "assetBucket": {
                  "type": "string"
                },
                "outputBucket": {
                  "type": "string"
                },
                "awsRegion": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "local": {
              "type": "object",
              "properties": {
                "assetPath": {
                  "type": "string"
                },
                "outputPath": {
                  "type": "string"
                }
              }
            },
            "minio": {
              "type": "object",
              "properties": {
                "endpoint": {
                  "type": "string"
                },
                "assetBucket": {
                  "type": "string"
                },
                "outputBucket": {
                  "type": "string"
                },
                "region": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "identity": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["none", "irsa", "podIdentity", "existingSecret"]
            },
            "irsa": {
              "type": "object",
              "properties": {
                "annotationKey": {
                  "type": "string",
                  "minLength": 1
                },
                "roleArn": {
                  "type": "string"
                }
              }
            },
            "podIdentity": {
              "type": "object",
              "properties": {
                "provider": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "existingSecret": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "keda": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "minReplicaCount": {
          "type": "integer",
          "minimum": 0
        },
        "maxReplicaCount": {
          "type": "integer",
          "minimum": 0
        },
        "pollingInterval": {
          "type": "integer",
          "minimum": 1
        },
        "cooldownPeriod": {
          "type": "integer",
          "minimum": 0
        },
        "queueLength": {
          "type": "string",
          "minLength": 1
        },
        "authentication": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "name": {
              "type": "string"
            },
            "podIdentity": {
              "type": "object",
              "properties": {
                "provider": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "trigger": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "minLength": 1
            },
            "queueURLFromEnv": {
              "type": "string",
              "minLength": 1
            },
            "awsRegion": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "postprocessJob": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "nameSuffix": {
          "type": "string",
          "minLength": 1
        },
        "image": {
          "type": "object",
          "properties": {
            "repository": {
              "type": "string",
              "minLength": 1
            },
            "tag": {
              "type": "string",
              "minLength": 1
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "ttlSecondsAfterFinished": {
          "type": "integer",
          "minimum": 0
        },
        "backoffLimit": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
